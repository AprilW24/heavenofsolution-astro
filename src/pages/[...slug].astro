---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  const posts = await getCollection('blog');
  
  const pagePaths = pages.map(page => ({
    params: { slug: page.id.replace(/\.mdx?$/, '') },
    props: { type: 'page', entry: page },
  }));
  
  const postPaths = posts.map(post => ({
    params: { slug: post.id.replace(/\.mdx?$/, '') },
    props: { type: 'post', entry: post },
  }));
  
  return [...pagePaths, ...postPaths];
}

const { type, entry } = Astro.props;
const { Content } = await render(entry);

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

const isContactPage = type === 'page' && entry.id === 'contact';
---

<Layout 
  title={entry.data.title} 
  description={entry.data.description}
  featuredImage={type === 'post' ? entry.data.featuredImage : undefined}
  articleDate={type === 'post' ? entry.data.pubDate : undefined}
>
  <article class="container" style="max-width: 800px; margin: 0 auto; padding-bottom: 5rem;">
    
    {type === 'post' ? (
      // Blog Post Layout
      <>
        {entry.data.category && (
          <div style="margin-bottom: 1.5rem;">
            <a 
              href={`/category/${entry.data.category.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`} 
              style="background: var(--primary-light); color: var(--primary); padding: 0.35rem 0.85rem; border-radius: 99px; font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; display: inline-block;"
            >
              {entry.data.category}
            </a>
          </div>
        )}

        <!-- Title -->
        <h1 style="font-size: 2.75rem; font-weight: 800; margin-bottom: 1.5rem; line-height: 1.25; letter-spacing: -0.02em;">
          {entry.data.title}
        </h1>

        <!-- Meta Info -->
        <div style="display: flex; align-items: center; gap: 1rem; color: var(--text-muted); font-size: 0.95rem; margin-bottom: 3rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border);">
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <span style="font-weight: 600; color: var(--text);">By April</span>
          </div>
          <span>&bull;</span>
          <div>
            {entry.data.pubDate ? formatDate(entry.data.pubDate) : ''}
          </div>
        </div>

        <!-- Featured Image -->
        {entry.data.featuredImage && (
          <div style="margin-bottom: 3rem; border-radius: 16px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.04);">
            <img 
              src={entry.data.featuredImage} 
              alt={entry.data.title} 
              style="width: 100%; height: auto; display: block;"
            />
          </div>
        )}
      </>
    ) : (
      // Static Page Layout
      <h1 style="font-size: 3rem; font-weight: 800; margin-bottom: 2.5rem; text-align: center; letter-spacing: -0.03em;">
        {entry.data.title}
      </h1>
    )}

    <!-- Content Body -->
    <div class="entry-content">
      <Content />
    </div>

    <!-- Contact Form (Only shown on the contact page) -->
    {isContactPage && (
      <div style="margin-top: 3.5rem; background: var(--bg-alt); border: 1px solid var(--border); padding: 2.5rem; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.02);">
        <h3 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--text);">Contact Us</h3>
        <p style="color: var(--text-muted); margin-bottom: 2rem; font-size: 0.95rem;">
          Send us your message using the form below. We will reply as soon as possible.
        </p>
        
        <!-- Contact Form using Web3Forms (Free service sent directly to email) -->
        <form action="https://api.web3forms.com/submit" method="POST" style="display: flex; flex-direction: column; gap: 1.5rem;">
          <!-- Replace this access_key with your key from web3forms.com -->
          <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
          <input type="hidden" name="subject" value="New Message from Heaven of Solution" />
          <input type="checkbox" name="botcheck" style="display: none;" />
 
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label for="name" style="font-weight: 600; font-size: 0.9rem; color: var(--text);">Full Name</label>
              <input type="text" name="name" id="name" required placeholder="Your Name" style="padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); outline: none; font-family: inherit; font-size: 0.95rem; transition: border-color 0.2s;" />
            </div>
            
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label for="email" style="font-weight: 600; font-size: 0.9rem; color: var(--text);">Email Address</label>
              <input type="email" name="email" id="email" required placeholder="name@email.com" style="padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); outline: none; font-family: inherit; font-size: 0.95rem; transition: border-color 0.2s;" />
            </div>
          </div>
 
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label for="message" style="font-weight: 600; font-size: 0.9rem; color: var(--text);">Your Message</label>
            <textarea name="message" id="message" rows="5" required placeholder="Write your message or question here..." style="padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); outline: none; font-family: inherit; font-size: 0.95rem; resize: vertical; transition: border-color 0.2s;"></textarea>
          </div>
 
          <button type="submit" style="background: var(--primary); color: white; border: none; padding: 1rem 2rem; border-radius: 8px; font-weight: 700; font-family: inherit; font-size: 1rem; cursor: pointer; transition: background 0.2s; align-self: flex-start;">
            Send Message
          </button>
        </form>
      </div>
    )}
  </article>
</Layout>

<style>
  input:focus, textarea:focus {
    border-color: var(--primary) !important;
    box-shadow: 0 0 0 3px var(--primary-light);
  }
</style>
