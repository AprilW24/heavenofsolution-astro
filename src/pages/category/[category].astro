---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  // Ambil semua kategori unik
  const categories = [...new Set(posts.map(post => post.data.category).filter(Boolean))];
  
  return categories.map(category => {
    const categorySlug = category.toLowerCase().replace(/\s+/g, '-');
    const filteredPosts = posts.filter(post => post.data.category === category)
      .sort((a, b) => {
        const dateA = new Date(a.data.pubDate || 0).getTime();
        const dateB = new Date(b.data.pubDate || 0).getTime();
        return dateB - dateA;
      });
      
    return {
      params: { category: categorySlug },
      props: { category, posts: filteredPosts },
    };
  });
}

const { category, posts } = Astro.props;

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  return date.toLocaleDateString('id-ID', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
---

<Layout title={`Kategori: ${category}`} description={`Kumpulan artikel panduan solusi untuk kategori ${category}.`}>
  <section style="background-color: var(--bg-alt); padding: 4rem 0; border-bottom: 1px solid var(--border); margin-top: -2.5rem;">
    <div class="container" style="text-align: center;">
      <span style="color: var(--primary); font-weight: 700; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; display: inline-block; margin-bottom: 0.5rem;">Kategori</span>
      <h1 style="font-size: 2.5rem; font-weight: 800; letter-spacing: -0.02em;">{category}</h1>
      <p style="color: var(--text-muted); margin-top: 0.5rem; font-size: 1.1rem;">
        Menampilkan <span style="font-weight: 700; color: var(--text);">{posts.length}</span> panduan solusi.
      </p>
    </div>
  </section>

  <section style="padding: 5rem 0;">
    <div class="container">
      
      <!-- Grid Cards -->
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2.5rem;">
        {posts.map((post) => (
          <article 
            style="display: flex; flex-direction: column; background: white; border: 1px solid var(--border); border-radius: 16px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.02); transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); cursor: pointer;"
            class="post-card"
            onclick={`window.location.href='/blog/${post.id}'`}
          >
            <!-- Card Image -->
            <div style="position: relative; aspect-ratio: 16/10; overflow: hidden; background-color: var(--bg-alt);">
              <img 
                src={post.data.featuredImage || "/wp-content/uploads/2021/08/HoV-1.png"} 
                alt={post.data.title}
                loading="lazy"
                style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;"
                class="card-img"
              />
            </div>
            
            <!-- Card Body -->
            <div style="padding: 1.75rem; flex: 1; display: flex; flex-direction: column;">
              <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.75rem; font-weight: 600;">
                {post.data.pubDate ? formatDate(post.data.pubDate) : ''}
              </div>
              <h3 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 0.75rem; line-height: 1.35; color: var(--text); transition: color 0.2s;">
                <a href={`/blog/${post.id}`} style="color: inherit;">
                  {post.data.title}
                </a>
              </h3>
              <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 1.5rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; flex: 1;">
                {post.data.description}
              </p>
              <div style="border-top: 1px solid var(--border); padding-top: 1rem; font-weight: 700; font-size: 0.9rem; color: var(--primary); display: flex; align-items: center; gap: 0.5rem;">
                Baca Selengkapnya &rarr;
              </div>
            </div>
          </article>
        ))}
      </div>
      
    </div>
  </section>

  <!-- CSS Hover & Interactive Effects -->
  <style>
    .post-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 30px rgba(83, 68, 244, 0.08);
      border-color: var(--primary-light);
    }
    .post-card:hover .card-img {
      transform: scale(1.05);
    }
    .post-card:hover h3 {
      color: var(--primary);
    }
  </style>
</Layout>
